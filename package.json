{
  "name": "randomapigenerator",
  "private": true,
  "version": "1.2.8",
  "author": "CodeFryDev (https://codefrydev.in)",
  "homepage": "https://github.com/codefrydev/RandomApiGenerator#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/codefrydev/RandomApiGenerator.git"
  },
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "dev": "concurrently -k \"cross-env BROWSER=none vite\" \"wait-on tcp:127.0.0.1:5173 && cross-env ELECTRON_IS_DEV=1 electron .\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "node --test \"test/**/*.test.cjs\" && vitest run",
    "preview": "vite preview",
    "electron:preview": "npm run build && electron .",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "@faker-js/faker": "^9.9.0",
    "@uiw/react-codemirror": "^4.25.9",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "async-exit-hook": "^2.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.randomapigenerator.app",
    "productName": "RandomApiGenerator",
    "icon": "build/icon.png",
    "extraResources": [
      {
        "from": "build",
        "to": "app-icons",
        "filter": [
          "icon.ico",
          "icon.icns",
          "icon.png",
          "app-icon.svg"
        ]
      }
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
